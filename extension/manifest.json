{
  "manifest_version": 3,
  "name": "Counselor Finder",
  "version": "1.0",
  "description": "Find counselor information from school websites.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}